# ---- Google OAuth ----
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ---- NextAuth ----
# Generate a strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
# Local development:
NEXTAUTH_URL=http://localhost:3000
# Production on Vercel:
# NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# ---- Database: Neon Postgres ----
# Use your Neon Postgres connection string. For Vercel, prefer the pooled URL.
DATABASE_URL="postgresql://user:pass@host-pooler.neon.tech/neondb?sslmode=require"

# ---- Optional: restrict the app to specific Google accounts ----
# If set, only these email addresses will be allowed to sign in.
# Commas, semicolons, spaces, and newlines are accepted separators.
# Leave blank to allow any Google account (for personal local use).
ALLOWED_EMAIL=you@gmail.com,friend@gmail.com
# ALLOWED_EMAILS=you@gmail.com,friend@gmail.com
